{
  "expo": {
    "name": "CAHS",
    "slug": "cahs",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "cahs",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cahs.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Used for secure sign in"
      }
    },
    "android": {
      "package": "com.cahs.app",
      "adaptiveIcon": {
        "backgroundColor": "#FEFCF9",
        "foregroundImage": "./assets/adaptive-icon.png"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#C47B47"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
